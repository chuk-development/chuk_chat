# Copy this file to `.env` and fill in the real credentials before running the app.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_FUNCTION_BILLING_ENDPOINT=billing/create-checkout-session
SUPABASE_SUBSCRIPTIONS_TABLE=user_subscriptions
SUPABASE_CHATS_TABLE=user_chats

STRIPE_PUBLISHABLE_KEY=pk_test_1234567890
STRIPE_MERCHANT_IDENTIFIER=merchant.com.example
STRIPE_RETURN_URL=chukchat://stripe-complete

# Used to derive per-user encryption keys. Keep this value secret.
ENCRYPTION_SECRET=super-secret-seed
