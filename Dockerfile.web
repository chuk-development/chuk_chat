# Stage 1: Build Flutter web
FROM ubuntu:24.04 AS build

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git unzip ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Flutter
ENV FLUTTER_VERSION=3.38.8
RUN git clone --depth 1 --branch ${FLUTTER_VERSION} https://github.com/flutter/flutter.git /opt/flutter
ENV PATH="/opt/flutter/bin:/opt/flutter/bin/cache/dart-sdk/bin:${PATH}"

RUN flutter precache --web
RUN flutter doctor -v

WORKDIR /app
COPY pubspec.yaml pubspec.lock ./
RUN flutter pub get

COPY . .

ARG SUPABASE_URL
ARG SUPABASE_ANON_KEY

# Generate web environment config (dart-define can be unreliable with dart2js)
RUN echo "// GENERATED - DO NOT EDIT" > lib/web_env.dart && \
    echo "const String webSupabaseUrl = '${SUPABASE_URL}';" >> lib/web_env.dart && \
    echo "const String webSupabaseAnonKey = '${SUPABASE_ANON_KEY}';" >> lib/web_env.dart && \
    cat lib/web_env.dart

RUN flutter build web --release \
    --dart-define=FEATURE_PROJECTS=false \
    --dart-define=FEATURE_IMAGE_GEN=false \
    --dart-define=FEATURE_MEDIA_MANAGER=true \
    --dart-define=FEATURE_VOICE_MODE=true

# Stage 2: Serve with nginx
FROM nginx:alpine

COPY --from=build /app/build/web /usr/share/nginx/html
COPY nginx.web.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
