<?xml version="1.0" encoding="utf-8"?>
<!-- Disable all cloud and device-to-device backups.
     This is critical for an E2E encrypted chat app — encryption keys
     and cached messages must never leave the device via backup. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="." />
    </device-transfer>
</data-extraction-rules>
