<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Network Security Configuration for chuk.chat

        This provides OS-level security in addition to Dio certificate pinning.
        Certificate pinning is handled in Dart code (lib/utils/certificate_pinning.dart)
    -->

    <!-- Base config: Block all cleartext (HTTP) traffic, only allow HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system CAs only -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Debug builds: Allow user-installed certificates for testing -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
